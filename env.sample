# ─────────────────────────────────────────────
# FAR — Flavour Airhis Resources
# Environment Variables Sample
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────


# ─── DATABASE ────────────────────────────────
# MongoDB Atlas connection string
# Get it from: https://cloud.mongodb.com → Your Cluster → Connect → Drivers
MONGODB_URI=

# ─── NEXTAUTH ────────────────────────────────
# Secret used to sign/encrypt session tokens.
# Generate one by running: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here

# The full URL of your app (no trailing slash)
# Development:
NEXTAUTH_URL=http://localhost:3000
# Production (replace with your actual domain):
# NEXTAUTH_URL=https://far-app.vercel.app


# ─── CLOUDINARY ──────────────────────────────
# Get these from: https://cloudinary.com → Dashboard
# Used server-side for uploads and deletions
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=


# Exposed to the browser (only cloud name is safe to expose)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=dl9mx2tvo

# ─── APP (optional) ──────────────────────────
# Base URL used for internal API calls in server components
# Usually the same as NEXTAUTH_URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
